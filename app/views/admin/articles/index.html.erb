<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-3xl font-bold text-gray-800">📋 Kelola Semua Artikel</h1>
    <p class="text-gray-500">Total: <%= @articles.total_count %> artikel</p>
  </div>
  <%= link_to "← Dashboard", admin_dashboard_path,
      class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Judul</th>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Penulis</th>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Kategori</th>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Views</th>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Tanggal</th>
        <th class="text-left px-4 py-3 text-gray-600 text-sm">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% @articles.each do |article| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="px-4 py-3 text-sm font-medium text-gray-800">
            <%= truncate(article.title, length: 40) %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500">
            <%= article.user&.email %>
          </td>
          <td class="px-4 py-3">
            <% if article.category %>
              <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs">
                <%= article.category.name %>
              </span>
            <% else %>
              <span class="text-gray-400 text-xs">-</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500">
            👁️ <%= article.views_count %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500">
            <%= article.created_at.strftime("%d %b %Y") %>
          </td>
          <td class="px-4 py-3">
            <div class="flex gap-2">
              <%= link_to "Lihat", article,
                  class: "text-blue-600 text-sm hover:underline" %>
              <%= link_to "Hapus", admin_article_path(article),
                  data: { turbo_method: :delete, turbo_confirm: "Yakin hapus artikel ini?" },
                  class: "text-red-600 text-sm hover:underline" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# PAGINATION %>
<div class="flex justify-center mt-6 gap-1">
  <% (1..@articles.total_pages).each do |page| %>
    <% if page == @articles.current_page %>
      <span class="w-8 h-8 flex items-center justify-center bg-red-600 text-white rounded text-sm font-bold"><%= page %></span>
    <% else %>
      <%= link_to page, admin_articles_path(page: page),
          class: "w-8 h-8 flex items-center justify-center border border-gray-300 rounded hover:bg-gray-100 text-sm" %>
    <% end %>
  <% end %>
</div>