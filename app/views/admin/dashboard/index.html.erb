<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-800">👑 Admin Dashboard</h1>
  <p class="text-gray-500">Selamat datang, <%= current_user.email %></p>
</div>

<%# STATISTIK %>
<div class="grid grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl font-bold text-red-600"><%= @total_articles %></p>
    <p class="text-gray-500 mt-2">Total Artikel</p>
  </div>
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl font-bold text-blue-600"><%= @total_users %></p>
    <p class="text-gray-500 mt-2">Total User</p>
  </div>
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl font-bold text-green-600"><%= @total_views %></p>
    <p class="text-gray-500 mt-2">Total Views</p>
  </div>
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl font-bold text-yellow-600"><%= @total_categories %></p>
    <p class="text-gray-500 mt-2">Total Kategori</p>
  </div>
</div>

<div class="grid grid-cols-2 gap-6">
  <%# ARTIKEL TERBARU %>
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-gray-800">📝 Artikel Terbaru</h2>
      <%= link_to "Kelola", admin_articles_path,
          class: "text-red-600 text-sm hover:underline" %>
    </div>
    <% @latest_articles.each do |article| %>
      <div class="border-b border-gray-100 py-3 flex justify-between items-center">
        <div>
          <p class="font-medium text-gray-800 text-sm"><%= truncate(article.title, length: 40) %></p>
          <p class="text-gray-400 text-xs"><%= article.user&.email %></p>
        </div>
        <div class="flex gap-2 items-center">
          <span class="text-gray-400 text-xs">👁️ <%= article.views_count %></span>
          <%= link_to "Hapus", admin_article_path(article),
              data: { turbo_method: :delete, turbo_confirm: "Yakin hapus?" },
              class: "text-red-500 text-xs hover:underline" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ARTIKEL TERPOPULER %>
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4">🔥 Artikel Terpopuler</h2>
    <% @popular_articles.each_with_index do |article, index| %>
      <div class="border-b border-gray-100 py-3 flex justify-between items-center">
        <div class="flex gap-3 items-center">
          <span class="text-2xl font-bold text-gray-200">#<%= index + 1 %></span>
          <div>
            <p class="font-medium text-gray-800 text-sm"><%= truncate(article.title, length: 35) %></p>
            <p class="text-gray-400 text-xs"><%= article.category&.name || "Tanpa kategori" %></p>
          </div>
        </div>
        <span class="text-red-600 font-bold text-sm">👁️ <%= article.views_count %></span>
      </div>
    <% end %>
  </div>
</div>