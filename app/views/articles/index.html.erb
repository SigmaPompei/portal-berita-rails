<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-800">📰 Daftar Artikel</h1>
  <% if user_signed_in? %>
    <%= link_to "➕ Tulis Artikel", new_article_path,
        class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 font-bold" %>
  <% end %>
</div>

<%# SEARCH BAR %>
<div class="bg-white rounded-lg shadow p-4 mb-4">
  <%= form_with url: articles_path, method: :get, local: true do |form| %>
    <div class="flex gap-2">
      <%= form.text_field :search,
          value: @search,
          placeholder: "Cari judul artikel...",
          class: "flex-1 border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-red-500" %>
      <%= form.submit "🔍 Cari",
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer font-bold" %>
      <% if @search.present? %>
        <%= link_to "✕ Reset", articles_path,
            class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
      <% end %>
    </div>
  <% end %>
</div>

<%# INFO HASIL SEARCH %>
<% if @search.present? %>
  <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-2 rounded mb-4 text-sm">
    🔍 Hasil pencarian untuk "<strong><%= @search %></strong>":
    <%= @articles.total_count %> artikel ditemukan
  </div>
  <% end %>

<%# FILTER KATEGORI %>
<div class="flex gap-2 mb-6 flex-wrap">
  <%= link_to "Semua", articles_path,
      class: "bg-gray-200 text-gray-700 px-3 py-1 rounded-full text-sm hover:bg-gray-300" %>
  <% Category.all.each do |category| %>
    <%= link_to category.name, category_path(category),
        class: "bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm hover:bg-red-200" %>
  <% end %>
</div>

<% if @articles.empty? %>
  <div class="bg-white rounded-lg shadow p-10 text-center text-gray-400">
    <p class="text-5xl mb-4">📭</p>
    <p class="text-lg">Belum ada artikel.</p>
  </div>
<% else %>
  <div class="grid gap-4">
    <% @articles.each do |article| %>
      <div class="bg-white rounded-lg shadow hover:shadow-md transition">
        <% if article.cover_image.attached? %>
          <%= image_tag article.cover_image,
              class: "w-full h-48 object-cover rounded-t-lg" %>
        <% else %>
          <div class="w-full h-48 bg-gray-200 rounded-t-lg flex items-center justify-center">
            <span class="text-gray-400 text-4xl">📰</span>
          </div>
        <% end %>

        <div class="p-6">
          <%# BADGE KATEGORI %>
          <% if article.category %>
            <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold mb-2 inline-block">
              <%= article.category.name %>
            </span>
          <% end %>

          <h2 class="text-xl font-bold text-gray-800 mb-2"><%= article.title %></h2>
          <p class="text-gray-600 mb-4"><%= truncate(article.body.to_plain_text, length: 120) %></p>
          <div class="flex justify-between items-center">
            <small class="text-gray-400 text-sm">
              ✍️ <%= article.user&.email || "Unknown" %> &nbsp;|&nbsp;
              📅 <%= article.created_at.strftime("%d %B %Y") %>
              &nbsp;|&nbsp;
              👁️ <%= article.views_count %>
            </small>
            <div class="flex gap-2">
              <%= link_to "👁️ Lihat", article,
                  class: "bg-gray-100 text-gray-700 px-3 py-1 rounded hover:bg-gray-200 text-sm" %>
              <% if user_signed_in? && article.user == current_user %>
                <%= link_to "✏️ Edit", edit_article_path(article),
                    class: "bg-blue-100 text-blue-700 px-3 py-1 rounded hover:bg-blue-200 text-sm" %>
                <%= link_to "🗑️ Hapus", article,
                    data: { turbo_method: :delete, turbo_confirm: "Yakin hapus?" },
                    class: "bg-red-100 text-red-700 px-3 py-1 rounded hover:bg-red-200 text-sm" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <%# PAGINATION %>
<div class="flex justify-between items-center mt-6 flex-wrap gap-4">
  <p class="text-sm text-gray-500">
    Menampilkan <%= @articles.offset_value + 1 %>–<%= [@articles.offset_value + @articles.length, @articles.total_count].min %>
    dari <%= @articles.total_count %> artikel
  </p>
  <div class="flex gap-1">
    <%# Tombol Previous %>
    <% if @articles.prev_page %>
      <%= link_to "←", articles_path(page: @articles.prev_page),
          class: "w-8 h-8 flex items-center justify-center border border-gray-300 rounded hover:bg-gray-100 text-sm" %>
    <% else %>
      <span class="w-8 h-8 flex items-center justify-center border border-gray-200 rounded text-gray-300 text-sm cursor-not-allowed">←</span>
    <% end %>

    <%# Nomor Halaman %>
    <% (1..@articles.total_pages).each do |page| %>
      <% if page == @articles.current_page %>
        <span class="w-8 h-8 flex items-center justify-center bg-red-600 text-white rounded text-sm font-bold"><%= page %></span>
      <% else %>
        <%= link_to page, articles_path(page: page),
            class: "w-8 h-8 flex items-center justify-center border border-gray-300 rounded hover:bg-gray-100 text-sm" %>
      <% end %>
    <% end %>

    <%# Tombol Next %>
    <% if @articles.next_page %>
      <%= link_to "→", articles_path(page: @articles.next_page),
          class: "w-8 h-8 flex items-center justify-center border border-gray-300 rounded hover:bg-gray-100 text-sm" %>
    <% else %>
      <span class="w-8 h-8 flex items-center justify-center border border-gray-200 rounded text-gray-300 text-sm cursor-not-allowed">→</span>
    <% end %>
  </div>
</div>
<% end %>