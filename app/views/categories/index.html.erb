<h1 class="text-3xl font-bold text-gray-800 mb-6">📂 Daftar Kategori</h1>

<div class="grid grid-cols-3 gap-4">
  <% @categories.each do |category| %>
    <div class="bg-white rounded-lg shadow p-6 text-center hover:shadow-md transition">
      <p class="text-4xl mb-3">📁</p>
      <h2 class="font-bold text-gray-800 mb-1"><%= category.name %></h2>
      <p class="text-gray-400 text-sm mb-3"><%= category.articles.count %> artikel</p>
      <%= link_to "Lihat Artikel", category_path(category),
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 text-sm" %>
    </div>
  <% end %>
</div>