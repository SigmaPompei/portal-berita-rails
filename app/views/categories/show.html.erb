<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-800">
    📂 Kategori: <%= @category.name %>
    <span class="text-lg text-gray-400 font-normal">(<%= @articles.count %> artikel)</span>
  </h1>
  <%= link_to "← Semua Kategori", categories_path,
      class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<% if @articles.empty? %>
  <div class="bg-white rounded-lg shadow p-10 text-center text-gray-400">
    <p class="text-5xl mb-4">📭</p>
    <p>Belum ada artikel di kategori ini.</p>
  </div>
<% else %>
  <div class="grid gap-4">
    <% @articles.each do |article| %>
      <div class="bg-white rounded-lg shadow hover:shadow-md transition p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-2"><%= article.title %></h2>
        <p class="text-gray-600 mb-3"><%= truncate(article.body.to_plain_text, length: 120) %></p>
        <div class="flex justify-between items-center">
          <small class="text-gray-400 text-sm">
            ✍️ <%= article.user&.email %> &nbsp;|&nbsp;
            📅 <%= article.created_at.strftime("%d %B %Y") %>
          </small>
          <%= link_to "👁️ Lihat", article,
              class: "bg-gray-100 text-gray-700 px-3 py-1 rounded hover:bg-gray-200 text-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>