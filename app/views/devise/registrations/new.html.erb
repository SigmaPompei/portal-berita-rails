<div class="min-h-screen bg-gray-100 flex items-center justify-center">
  <div class="bg-white rounded-lg shadow p-8 w-full max-w-md">
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">📝 Daftar Akun</h2>

    <% if resource.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <ul class="list-disc list-inside">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :username, "Username", class: "block text-gray-700 font-bold mb-2" %>
        <%= f.text_field :username,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-red-500",
            placeholder: "Contoh: johndoe" %>
        <p class="text-gray-400 text-xs mt-1">Tampil sebagai nama penulis artikel</p>
      </div>

      <div class="mb-4">
        <%= f.label :email, "Email", class: "block text-gray-700 font-bold mb-2" %>
        <%= f.email_field :email,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-red-500",
            placeholder: "emailkamu@gmail.com" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Password", class: "block text-gray-700 font-bold mb-2" %>
        <%= f.password_field :password,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-red-500",
            placeholder: "Minimal 6 karakter" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "Konfirmasi Password", class: "block text-gray-700 font-bold mb-2" %>
        <%= f.password_field :password_confirmation,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-red-500",
            placeholder: "Ulangi password" %>
      </div>

      <%= f.submit "Daftar", class: "w-full bg-red-600 text-white py-2 rounded hover:bg-red-700 cursor-pointer font-bold" %>
    <% end %>

    <p class="text-center mt-4 text-gray-500 text-sm">
      Sudah punya akun? <%= link_to "Login di sini", new_user_session_path, class: "text-red-600 hover:underline" %>
    </p>
  </div>
</div>