<head>
  <title>Belajar Rails</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
  <body class="bg-gray-100 min-h-screen">

    <%# NAVBAR %>
    <nav class="bg-red-600 shadow-lg">
      <div class="max-w-4xl mx-auto px-4 py-3 flex justify-between items-center">
        <div class="flex gap-6">
  <a href="/" class="text-white font-bold text-lg hover:text-red-200">🏠 Home</a>
  <a href="/articles" class="text-white font-bold text-lg hover:text-red-200">📄 Artikel</a>
  <a href="/categories" class="text-white font-bold text-lg hover:text-red-200">📂 Kategori</a>
</div>

        <div class="flex items-center gap-4">
          <% if user_signed_in? %>
            <span class="text-white text-sm">👤 <%= current_user.display_name %>
            <% if current_user.admin? %>
      <span class="bg-yellow-400 text-yellow-900 text-xs px-2 py-0.5 rounded-full ml-1 font-bold">ADMIN</span>
          <% end %>
            </span>
            <% if current_user.admin? %>
    <%= link_to "👑 Dashboard", admin_dashboard_path,
        class: "bg-yellow-400 text-yellow-900 text-sm font-bold px-3 py-1 rounded hover:bg-yellow-300" %>
          <% end %>
            <%= button_to "Logout", destroy_user_session_path,
                method: :delete,
                form: { style: "display: inline;" },
                class: "bg-white text-red-600 text-sm font-bold px-3 py-1 rounded hover:bg-red-100 cursor-pointer border-0" %>
          <% else %>
            <%= link_to "Login", new_user_session_path,
                class: "text-white font-bold hover:text-red-200" %>
            <%= link_to "Daftar", new_user_registration_path,
                class: "bg-white text-red-600 font-bold px-3 py-1 rounded hover:bg-red-100" %>
          <% end %>
          
        </div>
      </div>
    </nav>

    <%# FLASH MESSAGE %>
    <div class="max-w-4xl mx-auto px-4 mt-4">
      <% if notice %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
          ✅ <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
          ❌ <%= alert %>
        </div>
      <% end %>
    </div>

    <%# KONTEN UTAMA %>
    <main class="max-w-4xl mx-auto px-4 py-6">
      <%= yield %>
    </main>

    <%# FOOTER %>
    <footer class="bg-gray-800 text-gray-400 text-center py-4 mt-10">
      <p>© 2024 Belajar Rails — Dibuat dengan ❤️</p>
    </footer>

  </body>
</html>