<%# HERO SECTION %>
<div class="bg-white rounded-lg shadow p-12 text-center mb-8">
  <h1 class="text-4xl font-bold text-red-600 mb-4">🚀 Selamat Datang!</h1>
  <p class="text-gray-600 text-lg mb-6">
    Platform berbagi artikel sederhana dibuat dengan Ruby on Rails
  </p>
  <div class="flex gap-4 justify-center">
    <%= link_to "📄 Lihat Artikel", articles_path,
        class: "bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 font-bold text-lg" %>
    <% if user_signed_in? %>
      <%= link_to "✍️ Tulis Artikel", new_article_path,
          class: "bg-gray-200 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-300 font-bold text-lg" %>
    <% else %>
      <%= link_to "✍️ Mulai Menulis", new_user_registration_path,
          class: "bg-gray-200 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-300 font-bold text-lg" %>
    <% end %>
  </div>
</div>

<%# ARTIKEL TERPOPULER %>
<% if @popular_articles.any? %>
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">🔥 Artikel Terpopuler</h2>
    <div class="grid grid-cols-3 gap-4">
      <% @popular_articles.each do |article| %>
        <div class="bg-white rounded-lg shadow hover:shadow-md transition">
          <% if article.cover_image.attached? %>
            <%= image_tag article.cover_image,
                class: "w-full h-36 object-cover rounded-t-lg" %>
          <% else %>
            <div class="w-full h-36 bg-gray-200 rounded-t-lg flex items-center justify-center">
              <span class="text-gray-400 text-3xl">📰</span>
            </div>
          <% end %>
          <div class="p-4">
            <% if article.category %>
              <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold mb-2 inline-block">
                <%= article.category.name %>
              </span>
            <% end %>
            <h3 class="font-bold text-gray-800 text-sm mb-2"><%= truncate(article.title, length: 60) %></h3>
            <div class="flex justify-between items-center">
              <span class="text-xs text-gray-400">👁️ <%= article.views_count %> views</span>
              <%= link_to "Baca", article,
                  class: "bg-red-600 text-white px-3 py-1 rounded text-xs hover:bg-red-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ARTIKEL TERBARU %>
<% if @latest_articles.any? %>
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">🆕 Artikel Terbaru</h2>
    <div class="grid grid-cols-3 gap-4">
      <% @latest_articles.each do |article| %>
        <div class="bg-white rounded-lg shadow hover:shadow-md transition">
          <% if article.cover_image.attached? %>
            <%= image_tag article.cover_image,
                class: "w-full h-36 object-cover rounded-t-lg" %>
          <% else %>
            <div class="w-full h-36 bg-gray-200 rounded-t-lg flex items-center justify-center">
              <span class="text-gray-400 text-3xl">📰</span>
            </div>
          <% end %>
          <div class="p-4">
            <% if article.category %>
              <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold mb-2 inline-block">
                <%= article.category.name %>
              </span>
            <% end %>
            <h3 class="font-bold text-gray-800 text-sm mb-2"><%= truncate(article.title, length: 60) %></h3>
            <div class="flex justify-between items-center">
              <span class="text-xs text-gray-400">📅 <%= article.created_at.strftime("%d %b %Y") %></span>
              <%= link_to "Baca", article,
                  class: "bg-red-600 text-white px-3 py-1 rounded text-xs hover:bg-red-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# FITUR %>
<div class="grid grid-cols-3 gap-4">
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl mb-3">📝</p>
    <h3 class="font-bold text-gray-800 mb-2">Tulis Artikel</h3>
    <p class="text-gray-500 text-sm">Bagikan ide dan pengetahuanmu</p>
  </div>
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl mb-3">🔐</p>
    <h3 class="font-bold text-gray-800 mb-2">Akun Aman</h3>
    <p class="text-gray-500 text-sm">Login & register dengan mudah</p>
  </div>
  <div class="bg-white rounded-lg shadow p-6 text-center">
    <p class="text-4xl mb-3">📱</p>
    <h3 class="font-bold text-gray-800 mb-2">Responsif</h3>
    <p class="text-gray-500 text-sm">Tampilan rapi di semua perangkat</p>
  </div>
</div>